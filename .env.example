# ── Write backend (choose one or both) ───────────────────────────────────────

# API mode (preferred): POST /api/messages to Memory Database API
MEMORY_DATABASE_API_URL=http://localhost:3000
MEMORY_DATABASE_API_TOKEN=your_api_token_here

# PG mode (fallback): direct PostgreSQL connection
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Server ───────────────────────────────────────────────────────────────────

# HTTP port for the ingestor server
LOGIN_SERVER_PORT=3101

# ── Auth ─────────────────────────────────────────────────────────────────────

# Optional: protect the /sync UI with a token
# UI_TOKEN=your_ui_token_here

# ── Scheduler ────────────────────────────────────────────────────────────────

# Max concurrent running jobs (default: 1)
# SCHEDULER_CONCURRENCY=1

# Minimum delay (ms) after a job finishes before the next starts (default: 1000)
# SCHEDULER_JOB_SPACING_MS=1000

# Overlap window % for scheduled runs to avoid boundary edge misses (default: 10)
# SCHEDULE_SINCE_OVERLAP_PERCENT=10

# ── Data persistence ──────────────────────────────────────────────────────────

# Root directory for jobs, runs, and session data (default: .data/)
# DATA_DIR=/app/.data
